{
  "name": "mono-game",
  "private": true,
  "version": "1.0.0",
  "description": "Monorepo for web-based (React, Vite, Node.js) games.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prettier": "prettier --write .",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "coverage:open": "start coverage/index.html"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^2.0.5",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sass-embedded": "^1.97.2",
    "styled-components": "^6.1.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.5"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  }
}
